<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep all traffic on the canonical host. This runs before Laravel so a
    # stale/broken apex-domain application cache cannot affect admin routes.
    RewriteCond %{HTTP_HOST} ^zemtab\.com$ [NC]
    RewriteRule ^ https://www.zemtab.com%{REQUEST_URI} [R=301,L,NE]

    # Shared hosts sometimes point the domain at the Laravel project root.
    # Send every web request to the public front controller/assets directory.
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^((?!public/).*)$ public/$1 [L]
</IfModule>
