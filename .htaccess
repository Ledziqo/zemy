<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep all traffic on the canonical host. This runs before Laravel so a
    # stale/broken apex-domain application cache cannot affect admin routes.
    RewriteCond %{HTTP_HOST} ^zemtab\.com$ [NC]
    RewriteRule ^ https://www.zemtab.com%{REQUEST_URI} [R=301,L,NE]

    # Shared hosts sometimes point the domain at the Laravel project root.
    # Send every web request to the public front controller/assets directory.
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^((?!public/).*)$ public/$1 [L]
</IfModule>

# Never let the CDN retain apex-host redirects or transient application errors.
<IfModule mod_headers.c>
    SetEnvIf Host "^zemtab\.com$" ZEMTAB_APEX=1
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=ZEMTAB_APEX
    Header always set Pragma "no-cache" env=ZEMTAB_APEX
    Header always set Expires "0" env=ZEMTAB_APEX
</IfModule>
